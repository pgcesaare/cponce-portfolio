---
interface ExperienceItem {
  title: string;
  period: string;
  role: string;
  bullets: string[];
}

interface Props {
	title: string
	description: string
	ProfileName: string
	ProfileRole: string,
	ProfileSlogan: string
	FocusTitle: string
	FocusBullets: string[],
	SkillsTitle: string,
	SkillsBullets: string[],
	StrenghtsTitle: string,
    StrenghtsBullets: string[],
	SectionTitle: string,
	SectionExperienceItems: ExperienceItem[],
	PostCardsTitle: string,
	ResumeTitle: string,
	ResumeCaption: string
}

const { 
	title, 
	description, 
	ProfileName, 
	ProfileRole, 
	ProfileSlogan,
	FocusTitle,
	FocusBullets,
	SkillsTitle,
	SkillsBullets,
	StrenghtsTitle,
    StrenghtsBullets,
	SectionTitle,
	SectionExperienceItems,
	PostCardsTitle,
	ResumeTitle,
	ResumeCaption
} = Astro.props



import Aside from './Aside.astro';
import Content from './Content.astro';
import Section from './Section.astro';
import PostsCards from '../components/content_components/PostsCards.astro';
import Layout from './Layout.astro';
---

<Layout
	title={title}
	description={description}
	>
		<Aside
			ProfileName={ProfileName}
			ProfileRole={ProfileRole}
			ProfileSlogan={ProfileSlogan}
			FocusTitle={FocusTitle}
			FocusBullets={FocusBullets}
			SkillsTitle={SkillsTitle}
			SkillsBullets={SkillsBullets}
			StrenghtsTitle={StrenghtsTitle}
			StrenghtsBullets={StrenghtsBullets}
		/>
		<Content>
			<PostsCards
				title={PostCardsTitle}
			/>
		</Content>
		<Section 
			title={SectionTitle}
			ExperienceItems={SectionExperienceItems}
			ResumeTitle={ResumeTitle}
			ResumeCaption={ResumeCaption}
		/>

</Layout>