---
import type { GetStaticPaths, CollectionEntry } from "astro";
import { getCollection } from "astro:content";

import ProjectPage from "../../../templates/ProjectPage.astro";
import { getProjectBaseSlug, getProjectLanguageFromId } from "../../../utils/projectSlugs";

type ProjectPost = CollectionEntry<"projects">;

export const getStaticPaths: GetStaticPaths = async () => {
  const projects = await getCollection("projects");

  return projects
    .filter((project) => getProjectLanguageFromId(project.id) === "en")
    .map((project) => ({
      params: { slug: getProjectBaseSlug(project.id) },
      props: { project }
    }));
};

const { project } = Astro.props as { project: ProjectPost };
const labels = {
  eyebrow: "Project",
  publishedLabel: "Published",
  technologiesTitle: "Applied technologies",
  technologiesCaption: "Core tools and platforms used in this project.",
  articleEyebrow: "Case Study",
  articleTitle: "Project breakdown",
  resourcesTitle: "Resources",
  resourcesCaption: "Useful links to explore this project.",
  openLabel: "Open",
  copyLabel: "Copy",
  copiedLabel: "Copied!",
  resumeTitle: "Resume",
  resumeCaption: "Download PDF Version"
};
---

<ProjectPage project={project} locale="en" homeHref="/en" labels={labels} />
