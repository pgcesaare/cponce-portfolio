---
import type { GetStaticPaths } from "astro";

import ProjectPage from "../../../templates/ProjectPage.astro";
import { getLocalizedProjects, type UploadedProject } from "../../../utils/projects";

export const getStaticPaths: GetStaticPaths = async () => {
  const projects = await getLocalizedProjects("es");

  return projects.map((project) => ({
      params: { slug: project.slug },
      props: { project }
    }));
};

const { project } = Astro.props as { project: UploadedProject };
const labels = {
  eyebrow: "Proyecto",
  publishedLabel: "Publicado",
  technologiesTitle: "Tecnologias aplicadas",
  technologiesCaption: "Herramientas y plataformas principales usadas en este proyecto.",
  articleEyebrow: "Caso de estudio",
  articleTitle: "Desglose del proyecto",
  resourcesTitle: "Recursos",
  resourcesCaption: "Links utiles para explorar este proyecto.",
  openLabel: "Abrir",
  copyLabel: "Copiar",
  copiedLabel: "Copiado",
  resumeTitle: "Curriculum Vitae",
  resumeCaption: "Descarga Version PDF"
};
---

<ProjectPage project={project} locale="es" homeHref="/es" labels={labels} />
