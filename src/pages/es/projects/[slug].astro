---
import type { GetStaticPaths, CollectionEntry } from "astro";
import { getCollection } from "astro:content";

import ProjectPage from "../../../templates/ProjectPage.astro";
import { getProjectBaseSlug, getProjectLanguageFromId } from "../../../utils/projectSlugs";

type ProjectPost = CollectionEntry<"projects">;

export const getStaticPaths: GetStaticPaths = async () => {
  const projects = await getCollection("projects");

  return projects
    .filter((project) => getProjectLanguageFromId(project.id) === "es")
    .map((project) => ({
      params: { slug: getProjectBaseSlug(project.id) },
      props: { project }
    }));
};

const { project } = Astro.props as { project: ProjectPost };
const labels = {
  eyebrow: "Proyecto",
  publishedLabel: "Publicado",
  technologiesTitle: "Tecnologias aplicadas",
  technologiesCaption: "Herramientas y plataformas principales usadas en este proyecto.",
  articleEyebrow: "Caso de estudio",
  articleTitle: "Desglose del proyecto",
  resourcesTitle: "Recursos",
  resourcesCaption: "Links utiles para explorar este proyecto.",
  openLabel: "Abrir",
  copyLabel: "Copiar",
  copiedLabel: "Copiado",
  resumeTitle: "Curriculum Vitae",
  resumeCaption: "Descarga Version PDF"
};
---

<ProjectPage project={project} locale="es" homeHref="/es" labels={labels} />
