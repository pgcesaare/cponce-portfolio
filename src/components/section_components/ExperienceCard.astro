---
interface Props {
    title?: string;
    period?: string;
    role?: string;
}

const { title, period, role } = Astro.props
---

<div class="w-full py-4 flex flex-col gap-1.5 border-y border-border-default">
    <div class="flex flex-col gap-0.5">
        <div class="flex flex-col gap-1 sm:flex-row sm:items-end sm:justify-between">
            <p class="text-principal-text text-primary">{title}</p>
            <p class="text-secondary-text text-secondary">{period}</p>
        </div>
        <p class="text-principal-text text-accent-active">{role}</p>
    </div>
    <slot />
</div>
