---

interface Props {
    title: string,
    bullets: string[]
}

const { title, bullets = [] } = Astro.props

import CardContainer from "../CardContainer.astro";
import Bullets from '../Bullets.astro';
---


<CardContainer title={title}>
    <ul class="flex flex-col gap-0.5">
        {bullets.map((item) => (
            <Bullets>{item}</Bullets>
        ))}
    </ul>
</CardContainer>