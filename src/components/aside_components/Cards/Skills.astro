---

interface Props {
    title: string,
    bullets: string[]
}

const { title, bullets = []} = Astro.props

import CardContainer from "../CardContainer.astro";
import ChipContainer from '../../general/ChipContainer.astro';
import Chip from '../../general/Chip.astro';
---

<CardContainer title={title}>
    <ChipContainer>
        {bullets.map((item) => (
            <Chip>{item}</Chip>
        ))}
    </ChipContainer>    
</CardContainer>