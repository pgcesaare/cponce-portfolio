---

interface Props {
    name: string,
    role: string,
    slogan: string
}

const { name, role, slogan } = Astro.props

---

<div class="w-full h-fit px-4.5 py-5.5 flex flex-col items-center justify-center gap-4 text-center border-b border-border-default sm:flex-row sm:justify-start sm:text-left">
    <div class="w-20 shrink-0 flex justify-center items-center object-contain">
        <img class="rounded-full border-2 border-ring" src="/profile.jpg" alt="Foto de perfil de César Ponce" />
    </div>
    <section class="w-full flex flex-col gap-0.5 sm:w-47.5">
        <h3 class="text-title-h3 text-primary">{name}</h3>
        <p class="text-principal-text text-accent-primary">{role}</p>
        <p class="text-secondary-text text-secondary">{slogan}</p>
    </section>
</div>
