---
import Github from "../../assets/Github.astro";
import Linkedin from "../../assets/Linkedin.astro";
import Email from "../../assets/Email.astro";

const generalLinks = [
    { label: "LinkedIn", Icon: Linkedin },
    { label: "GitHub", Icon: Github },
    { label: "Email", Icon: Email }
];
---

<footer class="w-full border-t border-border-default px-4.5 py-4.5">
    <div class="flex flex-col gap-3">
        <div class="flex items-center justify-between gap-3">
            <p class="text-principal-text text-primary">Links</p>
            <span class="text-secondary-text text-secondary">General</span>
        </div>

        <nav aria-label="Links generales" class="grid grid-cols-3 gap-2.5">
            {generalLinks.map(({ label, Icon }) => (
                <div class="flex flex-col items-center justify-center gap-2 rounded-xl border border-border-default bg-bg-elevated px-3 py-3 text-center transition-colors">
                    <Icon class="h-5 w-5" />
                    <span class="text-secondary-text text-secondary">{label}</span>
                </div>
            ))}
        </nav>
    </div>
</footer>
