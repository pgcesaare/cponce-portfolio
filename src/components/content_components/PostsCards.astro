---

interface Props {
    title: string
}

const { title } = Astro.props

import ProjectsExplorer from "./ProjectsExplorer.jsx";
import { getCollection } from "astro:content";
import {
    getProjectBaseSlug,
    getProjectLanguageFromId
} from "../../utils/projectSlugs";

const currentLanguage = Astro.url.pathname.startsWith("/es") ? "es" : "en";

const posts = (await getCollection("projects"))
    .filter((project) => getProjectLanguageFromId(project.id) === currentLanguage)
    .filter((project, index, projects) => {
        const baseName = getProjectBaseSlug(project.id);

        return (
            projects.findIndex(
                (candidate) => getProjectBaseSlug(candidate.id) === baseName
            ) === index
        );
    });

const labels =
    currentLanguage === "es"
        ? {
            searchPlaceholder: "Buscar",
            clearSearchLabel: "Limpiar busqueda",
            allTechnologiesLabel: "Todas",
            scrollLeftLabel: "Desplazar tecnologias a la izquierda",
            scrollRightLabel: "Desplazar tecnologias a la derecha",
            emptyStateTitle: "No se encontraron proyectos",
            emptyStateCaption: "Prueba con otro nombre o cambia la tecnologia.",
            readMoreLabel: "mas",
            singleResultLabel: "1 proyecto encontrado",
            multipleResultsLabel: "{count} proyectos encontrados"
        }
        : {
            searchPlaceholder: "Search",
            clearSearchLabel: "Clear search",
            allTechnologiesLabel: "All",
            scrollLeftLabel: "Scroll technologies left",
            scrollRightLabel: "Scroll technologies right",
            emptyStateTitle: "No projects found",
            emptyStateCaption: "Try a different name or switch the technology filter.",
            readMoreLabel: "more",
            singleResultLabel: "1 project found",
            multipleResultsLabel: "{count} projects found"
        };

const serializedPosts = posts.map((project) => ({
    image: project.data.image,
    date: project.data.date.toLocaleDateString(
        currentLanguage === "es" ? "es-MX" : "en-US",
        {
            year: "numeric",
            month: "short",
            day: "numeric"
        }
    ),
    title: project.data.title,
    description: project.data.description,
    href: `/${currentLanguage}/projects/${getProjectBaseSlug(project.id)}`,
    tags: project.data.tags
}));
---
<ProjectsExplorer
    client:load
    title={title}
    posts={serializedPosts}
    labels={labels}
/>
